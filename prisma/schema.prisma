// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserGender {
  MALE
  FEMALE
  OTHER
}

enum ServiceTargetGender {
  MALE
  FEMALE
  UNISEX
}

model User {
  id        String   @id @default(uuid())
  role      String   @default("CUSTOMER") // CUSTOMER, SELLER, ADMIN
  name      String
  phone     String?
  gender    UserGender?
  email     String?  @unique
  password  String   @default("")
  isActive  Boolean  @default(true)
  noShowCount Int    @default(0)
  createdAt DateTime @default(now())

  salons    Salon[]  @relation("OwnerSalons")
  bookings  Booking[]
  reviews   Review[]
}

model Salon {
  id         String   @id @default(uuid())
  ownerId    String
  owner      User     @relation("OwnerSalons", fields: [ownerId], references: [id])

  name       String
  address    String
  lat        Float?
  lng        Float?
  openTime   String
  closeTime  String
  images     String?
  categories String?
  createdAt  DateTime @default(now())

  staff      Staff[]
  services   Service[]
  bookings   Booking[]
  reviews    Review[]
}

model Staff {
  id        String   @id @default(uuid())
  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id])

  name      String
  gender    UserGender?
  skills    String?
  isActive  Boolean  @default(true)

  services  StaffService[]
  availability StaffAvailability[]
  timeOff   StaffTimeOff[]
  bookings  Booking[]
}

model Service {
  id        String   @id @default(uuid())
  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id])

  name      String
  price     Int? // legacy fallback; no longer used for booking math
  duration  Int? // legacy fallback; no longer used for booking math

  staff     StaffService[]
  bookings  BookingService[]
  variants  ServiceVariant[]
}

model ServiceVariant {
  id           String              @id @default(uuid())
  serviceId    String
  service      Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  targetGender ServiceTargetGender
  price        Int
  duration     Int // minutes
  createdAt    DateTime            @default(now())

  bookingItems BookingService[]

  @@unique([serviceId, targetGender])
}

model StaffService {
  id        String   @id @default(uuid())
  staffId   String
  serviceId String

  staff     Staff   @relation(fields: [staffId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@unique([staffId, serviceId])
}

model StaffAvailability {
  id         String @id @default(uuid())
  staffId    String
  staff      Staff  @relation(fields: [staffId], references: [id])

  dayOfWeek  Int    // 0-6
  startTime  String
  endTime    String
}

model StaffTimeOff {
  id        String   @id @default(uuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id])

  date      DateTime
  startTime String
  endTime   String
}

model Booking {
  id            String   @id @default(uuid())
  userId        String
  salonId       String
  staffId       String

  user          User     @relation(fields: [userId], references: [id])
  salon         Salon    @relation(fields: [salonId], references: [id])
  staff         Staff    @relation(fields: [staffId], references: [id])

  services      BookingService[]

  startTime     DateTime
  endTime       DateTime
  totalAmount   Int

  status        String @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  paymentStatus String @default("PENDING") // PENDING, PARTIAL, PAID, REFUNDED
  actionToken   String? @unique

  createdAt     DateTime @default(now())

  payment       Payment?

  @@unique([staffId, startTime]) // prevents double booking
}

model BookingService {
  id        String   @id @default(uuid())
  bookingId String
  serviceId String
  variantId String?
  serviceNameAtBooking String
  targetGenderAtBooking ServiceTargetGender
  priceAtBooking Int
  durationAtBooking Int

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id])
  variant   ServiceVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([bookingId, serviceId])
}

model Payment {
  id        String   @id @default(uuid())
  bookingId String   @unique
  amount    Int
  fee       Int
  status    String
  razorpayId String?

  booking   Booking  @relation(fields: [bookingId], references: [id])
}

model Review {
  id       String @id @default(uuid())
  userId   String
  salonId  String
  rating   Int
  comment  String?
  createdAt DateTime @default(now())

  user     User  @relation(fields: [userId], references: [id])
  salon    Salon @relation(fields: [salonId], references: [id])
}

